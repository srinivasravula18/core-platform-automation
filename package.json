{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-playwright.mjs",
    "dev": "vite --host 0.0.0.0 --port 3000 --strictPort",
    "dev:frontend": "vite --host 0.0.0.0 --port 3000 --strictPort",
    "dev:backend": "tsx server.ts",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "start:backend": "node dist/server.cjs",
    "start:frontend": "node scripts/frontend-server.mjs",
    "check:gemini": "node scripts/check-gemini-rest.mjs",
    "eval:agents": "tsx scripts/agent-evals.ts",
    "eval:routing": "tsx scripts/eval-routing.ts",
    "eval:coercion": "tsx scripts/eval-coercion.ts",
    "eval:prioritization": "tsx scripts/eval-prioritization.ts",
    "benchmark:agents": "tsx scripts/benchmark-agents.ts",
    "benchmark:behavior": "tsx scripts/benchmark-behavior.ts",
    "playwright:install": "node scripts/ensure-playwright.mjs",
    "playwright:deps": "playwright install-deps chromium",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('server.js',{force:true});\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vscode/ripgrep": "^1.18.0",
    "ai": "^6.0.195",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
