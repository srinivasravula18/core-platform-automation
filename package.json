{
  "name": "core-platform-automation",
  "private": true,
  "version": "1.0.0",
  "description": "Standalone list-view E2E automation environment for Core Platform.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:dashboard": "vite build",
    "dev:dashboard": "vite --host 127.0.0.1",
    "start": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\start-list-view-test-environment.ps1 -SkipStart",
    "test:ui:list-view:env": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\start-list-view-test-environment.ps1",
    "test:ui:list-view:report": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\start-list-view-report.ps1 -AllowMissing -Foreground",
    "test:ui:list-view:full": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1",
    "test:ui:list-view:full:headed": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Headed",
    "test:ui:list-view:full:no-reset": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -SkipReset",
    "test:ui:list-view:admin": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface admin -SkipReset",
    "test:ui:list-view:admin:headed": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface admin -SkipReset -Headed",
    "test:ui:list-view:admin:lifecycle": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface admin -SkipReset -Scenario \"@lifecycle|@recycle|Bulk delete\"",
    "test:ui:list-view:keystone": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface keystone -SkipReset",
    "test:ui:list-view:keystone:headed": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface keystone -SkipReset -Headed",
    "test:ui:list-view:keystone:lifecycle": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface keystone -SkipReset -Scenario \"@lifecycle|@recycle|Bulk delete\"",
    "test:ui:list-view:workflow": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface all -SkipReset -Scenario \"@workflow\"",
    "test:ui:list-view:settings": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface all -SkipReset -Scenario \"Settings modal|Filters|Columns|Sharing|Preferences|Hierarchy\"",
    "test:ui:list-view:search": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface all -SkipReset -Scenario \"Search|Search navigation|Search empty state\"",
    "test:ui:list-view:api": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\run-list-view-regression.ps1 -Surface api -SkipReset",
    "test:ui:list-view:list": "npx playwright test --list -c tests/e2e/playwright.list-view-regression.config.ts",
    "stop:all": "powershell -ExecutionPolicy Bypass -File .\\tests\\scripts\\stop-all.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  }
}
