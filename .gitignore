# Generated test-checklist & feature-audit docs
docs/test-checklists/
docs/CORE-PLATFORM-FEATURE-AUDIT.md
CORE-PLATFORM-FEATURE-AUDIT.md

/.testflow-pw
# Local backup snapshots
*.bak

# QA requirements-AI sweep artifacts (local test runs — not source)
scripts/*.ps1
scripts/*.csv
scripts/*-json/
scripts/backend.log
# Local testing artifacts in any scripts subfolder (skillopt etc.): result/agent-response
# JSONs, runner scripts, and logs — never source.
scripts/**/*.ps1
scripts/**/*.json
scripts/**/*.log
scripts/**/cases-json/
scripts/**/*-json/

# Claude Code local workspace
.claude/
.testflow-run-memory.json

**/json.bak-project-cleanup/
.aiqa-live/

# Record & Play — desktop agent. node_modules (production-only) + compiled dist ARE committed so
# machines without npm access get a ready-to-run, self-contained bundle (just run start.bat).
# Negations override the global node_modules/ and dist/ ignores above (re-include the dir, then its
# contents). Only runtime state + the huge browser binaries stay out of git.
!agent/node_modules/
!agent/node_modules/**
!agent/dist/
!agent/dist/**
agent/config.json
agent/logs/
agent/playwright/
# Keep huge browser downloads (chromium-*) out of git, but ship the tiny video/deps helpers
# (ffmpeg, winldd) inside the downloadable bundle.
agent/browsers/*
!agent/browsers/ffmpeg-*/
!agent/browsers/winldd-*/
# Uploaded run artifacts (cloud host storage, not source)
/automation-artifacts
