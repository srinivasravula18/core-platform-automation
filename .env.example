# Supported AI providers. Keys can also be set in Settings → AI Providers.
# Gemini: use a Google AI Studio API key, not an OAuth/access token.
# The Google AI SDK also supports GOOGLE_GENERATIVE_AI_API_KEY.
# GEMINI_API_KEY="AIza..."
# OpenAI.
# OPENAI_API_KEY="sk-..."
# Anthropic / Claude.
# ANTHROPIC_API_KEY="sk-ant-..."

# CRED_ENC_KEY: 32-byte key used to encrypt stored website credentials at rest.
# A derived dev key is used if unset — set a real value for production.
# CRED_ENC_KEY="change-me-to-a-long-random-string"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ============================================================================
# DATABASE — use a SEPARATE database per environment.
# Each environment has its OWN .env (.env.local for local, .env on the server),
# and .env* is gitignored — so local and production never share data as long as
# DATABASE_URL points at different databases. If DATABASE_URL is unset the app
# falls back to a local JSON file (.testflow-data.json) — fine for a throwaway
# local run, but production should ALWAYS set a real DATABASE_URL.
#
#   LOCAL (.env.local):       run `npm run db:up` (docker Postgres) then:
#     DATABASE_URL=postgres://postgres@localhost:5432/testflowai
#
#   PRODUCTION (.env on the server): point at the PRODUCTION Postgres — a
#   different host/db than local, so the two never collide:
#     DATABASE_URL=postgres://<user>:<pass>@<prod-db-host>:5432/testflowai_prod
# ============================================================================
# DATABASE_URL=postgres://postgres@localhost:5432/testflowai

# ============================================================================
# GIT AGENT SOURCE REPO — the application's source code the agents grep/read as
# the "source of truth" for code-grounded answers. Set this per environment to
# the path of the cloned source repo ON THAT MACHINE (read by gitAgentService).
#
#   LOCAL (.env.local):       GIT_AGENT_TARGET_REPO=D:\core-platform
#   PRODUCTION (.env):        GIT_AGENT_TARGET_REPO=/home/ubuntu/projects/core-platform
#
# The path must be a real git checkout (contains a .git folder) on that server,
# kept in sync (git pull) so the agent reads current code. CORE_PLATFORM_REPO is
# accepted as an alias.
# ============================================================================
# GIT_AGENT_TARGET_REPO=/home/ubuntu/projects/core-platform

# ============================================================================
# The LangGraph.js agent workflow runtime (durable checkpointing, typed state,
# single retry owner) is the DEFAULT engine — no flag needed. Set
# AGENT_GRAPH_V2=0 only as an emergency kill switch to fall back to the legacy
# procedural pipeline.
#
# Production requires DATABASE_URL (Postgres) — the checkpointer factory fails
# closed (refuses to start) rather than silently falling back to a non-durable
# in-memory saver in a production deployment. Local dev without DATABASE_URL
# uses the in-memory saver automatically.
# ============================================================================
# AGENT_GRAPH_V2=0

# ============================================================================
# Bug-investigation framework flags (all default OFF = exact current behavior;
# they layer on the AGENT_GRAPH_V2 test-run graph):
#   AGENT_INVESTIGATE — failure investigation node: deterministic pre-analysis +
#     LLM classification, business-rule validation of API read-backs, the flake
#     re-run probe, and the intent-outcome judge that catches passing-but-wrong
#     mutation cases (suspicious PASS defects).
#   AGENT_ANALYST — per-run release-intelligence report (pass-rate deltas,
#     regressions, risk score 0-100, ship/caution/block) stored on the run.
#   VISUAL_REGRESSION — report-only per-step screenshot baseline diffing;
#     baselines seed from passing runs under evidence/baselines/.
# ============================================================================
# AGENT_INVESTIGATE=1
# AGENT_ANALYST=1
# VISUAL_REGRESSION=1

# ============================================================================
# REMOTE_AGENT_V1 — dark-launch flag for Record & Play via the local desktop agent.
# Unset or 0 = feature fully inert: no agent routes, no WS gateway, no scheduler, and
# the frontend renders no agent UI (the legacy cloud-side codegen recorder is unchanged).
# Set to 1 to enable the downloadable TestFlow Desktop Agent (localhost:2424) that runs
# Playwright locally and connects outbound to the cloud. Recommended with DATABASE_URL set
# for durable agent identity, though JSON-file mode works for local dev.
# ============================================================================
# REMOTE_AGENT_V1=1

# ============================================================================
# CASE_VERSIONING — test-case revision history is ON by default (no env var needed): every content
# change (title/description/preconditions/steps) appends an immutable snapshot to case_revisions;
# operational-only edits (status/folder/tags) do NOT mint a revision. Postgres only. This var is only
# an escape hatch to DISABLE it (set 0/false/off) and fall back to no history.
# ============================================================================
# CASE_VERSIONING=0

# ============================================================================
# EVIDENCE_ORACLE_V1 — dark-launch flag for evidence-grounded bug finding. Off/unset = today's
# behavior byte-for-byte (assertion verbs trusted 1:1). On = observed DOM state (disabled/readonly/
# value/selected) flows to the compiler so state assertions are validated against reality instead of
# guessed — stops false failures from assumed UI behavior. See
# docs/plans/evidence-grounded-bug-finding-plan.md.
# ============================================================================
# EVIDENCE_ORACLE_V1=1

BACKEND_PORT=3001
VITE_BACKEND_URL=http://localhost:3001
