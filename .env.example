# Supported AI providers. Keys can also be set in Settings → AI Providers.
# Gemini: use a Google AI Studio API key, not an OAuth/access token.
# The Google AI SDK also supports GOOGLE_GENERATIVE_AI_API_KEY.
# GEMINI_API_KEY="AIza..."
# OpenAI.
# OPENAI_API_KEY="sk-..."
# Anthropic / Claude.
# ANTHROPIC_API_KEY="sk-ant-..."

# CRED_ENC_KEY: 32-byte key used to encrypt stored website credentials at rest.
# A derived dev key is used if unset — set a real value for production.
# CRED_ENC_KEY="change-me-to-a-long-random-string"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ============================================================================
# DATABASE — use a SEPARATE database per environment.
# Each environment has its OWN .env (.env.local for local, .env on the server),
# and .env* is gitignored — so local and production never share data as long as
# DATABASE_URL points at different databases. If DATABASE_URL is unset the app
# falls back to a local JSON file (.testflow-data.json) — fine for a throwaway
# local run, but production should ALWAYS set a real DATABASE_URL.
#
#   LOCAL (.env.local):       run `npm run db:up` (docker Postgres) then:
#     DATABASE_URL=postgres://postgres@localhost:5432/testflowai
#
#   PRODUCTION (.env on the server): point at the PRODUCTION Postgres — a
#   different host/db than local, so the two never collide:
#     DATABASE_URL=postgres://<user>:<pass>@<prod-db-host>:5432/testflowai_prod
# ============================================================================
# DATABASE_URL=postgres://postgres@localhost:5432/testflowai

# ============================================================================
# GIT AGENT SOURCE REPO — the application's source code the agents grep/read as
# the "source of truth" for code-grounded answers. Set this per environment to
# the path of the cloned source repo ON THAT MACHINE (read by gitAgentService).
#
#   LOCAL (.env.local):       GIT_AGENT_TARGET_REPO=D:\core-platform
#   PRODUCTION (.env):        GIT_AGENT_TARGET_REPO=/home/ubuntu/projects/core-platform
#
# The path must be a real git checkout (contains a .git folder) on that server,
# kept in sync (git pull) so the agent reads current code. CORE_PLATFORM_REPO is
# accepted as an alias.
# ============================================================================
# GIT_AGENT_TARGET_REPO=/home/ubuntu/projects/core-platform

BACKEND_PORT=3001
VITE_BACKEND_URL=http://localhost:3001
