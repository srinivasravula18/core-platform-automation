# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Datastores (native local processes; no Docker required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atp
REDIS_URL=redis://localhost:6379

# --- Evidence store (local FS in dev; S3/MinIO in prod) ---
EVIDENCE_DIR=./evidence-store

# --- Agent artifact workspace (git-backed) ---
WORKSPACE_DIR=./workspace

# --- Tracing (OTel -> Langfuse via OTLP). Leave unset to disable. ---
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Target platform org credentials are stored encrypted in the DB (org_credentials),
#     referenced by handle, and injected only at execution time. NEVER put org secrets here. ---
ATP_SECRET_KEY=dev-only-change-me-32-bytes-minimum
