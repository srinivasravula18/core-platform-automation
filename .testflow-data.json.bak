              "action": "Open https://ops.acchindra.com/shockwave.",
              "expected": "Keystone application loads or shows the login screen."
            },
            {
              "action": "If login is shown, enter username/email \"adminacc\" and password \"adminacc@2026\", then click the sign-in/login control.",
              "expected": "User is authenticated and lands on https://ops.acchindra.com/shockwave/."
            },
            {
              "action": "Using only the keyboard, tab through the reachable post-login page controls.",
              "expected": "Every reachable interactive control has a visible focus indicator and focus order does not get trapped."
            },
            {
              "action": "If the Keystone app launcher is visible, open it using keyboard interaction and search for the Admin-created app name.",
              "expected": "The launcher can be reached and operated by keyboard; the created app result is visible to the admin user."
            },
            {
              "action": "Verify any visible search field or login field has an accessible label or clear programmatic name.",
              "expected": "Screen-reader users can identify the purpose of each reachable input."
            },
            {
              "action": "Verify no persistent loading or error state prevents keyboard users from reaching the app launcher; if no visible controls render, log the same blocked condition found during inspection.",
