          "agent": "PlaywrightAgent",
          "status": "completed",
          "output": {
            "scripts": [
              {
                "test_case_title": "Verify Keystone reflects Admin list-view changes with accessible list behavior",
                "filename": "verify-keystone-reflects-admin-list-view-changes-with-accessible-list-behavior-tc-708f-2.spec.ts",
                "code": "import { test, expect, type Locator, type Page, type TestInfo } from '@playwright/test';\n\nasync function waitForPageReady(page: Page) {\n  await page.waitForLoadState('domcontentloaded');\n  await page.waitForFunction(() => document.readyState !== 'loading', undefined, { timeout: 15000 }).catch(() => undefined);\n  await page.waitForLoadState('networkidle', { timeout: 15000 }).catch(() => undefined);\n  await expect(page.locator('body')).toBeVisible({ timeout: 15000 });\n}\n\nasync function guardedLogin(page: Page) {\n  // Inspector observation was blocked at /admin/?nav=apps and exposed no login fields,\n  // navigation, forms, tables, assertion targets, or concrete Keystone list-view label.\n  // If authentication is required, configure Playwright storageState via auth.setup.ts before running this test.\n  await waitForPageReady(page);\n}\n\nasync function safeCount(locator: Locator) {\n  return locator.count().catch(() => 0);\n}\n\nasync function visibleCount(locator: Locator) {\n  const count = await safeCount(locator);\n  let visible = 0;\n\n  for (let index = 0; index < count; index += 1) {\n    if (await locator.nth(index).isVisible().catch(() => false)) {\n      visible += 1;\n    }\n  }\n\n  return visible;\n}\n\nasync function listContextCount(page: Page) {\n  const [navigationCount, tableCount, gridCount, listCount] = await Promise.all([\n    visibleCount(page.getByRole('navigation')),\n    visibleCount(page.getByRole('table')),\n    visibleCount(page.getByRole('grid')),\n    visibleCount(page.getByRole('list')),\n  ]);\n\n  return navigationCount + tableCount + gridCount + listCount;\n}\n\nasync function attachScreenshot(page: Page, testInfo: TestInfo, name: string) {\n  await testInfo.attach(name, {\n    body: await page.screenshot({ fullPage: true }),\n    contentType: 'image/png',\n  });\n}\n\nasync function annotateBlocked(testInfo: TestInfo, description: string) {\n  testInfo.annotations.push({\n    type: 'blocked',\n    description,\n  });\n}\n\nasync function markBlockedAndSkip(testInfo: TestInfo, description: string, message: string) {\n  await annotateBlocked(testInfo, description);\n  test.skip(true, message);\n}\n\ntest.describe('Verify Keystone reflects Admin list-view changes with accessible list behavior', () => {\n  test('Verify Keystone reflects Admin list-view changes with accessible list behavior', async ({ page }, testInfo) => {\n    await page.goto('/admin/?nav=apps', { waitUntil: 'domcontentloaded' });\n    await guardedLogin(page);\n\n    await expect.soft(page).toHaveURL(/\\/admin\\//);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await attachScreenshot(page, testInfo, 'step-1-admin-page');\n\n    // Grounded inspector context: /admin/?nav=apps returned no visible navigation, forms,\n    // tables, assertion targets, or concrete Keystone list-view label to compare.\n    const initialListContextCount = await listContextCount(page);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await attachScreenshot(page, testInfo, 'step-2-navigation-and-list-evidence');\n\n    if (initialListContextCount === 0) {\n      await markBlockedAndSkip(\n        testInfo,\n        'Inspector observed no visible navigation, forms, tables, assertion targets, or concrete Admin list-view change at /admin/?nav=apps.',\n        'Blocked: inspection did not identify a concrete Keystone/Admin list-view target to compare.'\n      );\n      return;\n    }\n\n    const loadingTextCount = await page.getByText(/loading/i).count().catch(() => 0);\n    const errorTextCount = await page.getByText(/error/i).count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await attachScreenshot(page, testInfo, 'step-3-list-state-evidence');\n\n    expect.soft(loadingTextCount, 'List view should not remain in an indefinite loading state.').toBe(0);\n    expect.soft(errorTextCount, 'List view should not show an error state.').toBe(0);\n\n    await page.reload({ waitUntil: 'domcontentloaded' });\n    await waitForPageReady(page);\n\n    const reflectedListAfterReload = await listContextCount(page);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await attachScreenshot(page, testInfo, 'step-4-reload-evidence');\n\n    if (reflectedListAfterReload === 0) {\n      await markBlockedAndSkip(\n        testInfo,\n        'Blocked after reload: no visible Keystone list context was exposed through a navigation landmark, table, grid, or list.',\n        'Blocked: Keystone list context was not available after reload for the inspected page.'\n      );\n      return;\n    }\n\n    expect.soft(\n      reflectedListAfterReload,\n      'A Keystone list context should remain visible after reload once the target list-view is identified.'\n    ).toBeGreaterThan(0);\n\n    await page.keyboard.press('Tab');\n    await expect.soft(page.locator('body')).toBeVisible();\n\n    const activeElementHasName = await page.evaluate(() => {\n      const element = document.activeElement as HTMLElement | null;\n      if (!element || element === document.body) return false;\n\n      return Boolean(\n        element.getAttribute('aria-label') ||\n          element.getAttribute('aria-labelledby') ||\n          element.textContent?.trim() ||\n          (element as HTMLInputElement).labels?.length\n      );\n    });\n    await attachScreenshot(page, testInfo, 'step-5-accessibility-focus-evidence');\n\n    expect.soft(activeElementHasName, 'Focused control should have an accessible name.').toBeTruthy();\n    expect(\n      reflectedListAfterReload,\n      'Keystone list context should be visible through a table, grid, list, or navigation landmark.'\n    ).toBeGreaterThan(0);\n  });\n});\n"
              },
              {
                "test_case_title": "Verify Keystone reflects Admin list-view changes with accessible list behavior",
                "filename": "verify-keystone-reflects-admin-list-view-changes-with-accessible-list-behavior-tc-708f-1.spec.ts",
                "code": "import { test, expect } from '@playwright/test';\n\nconst USERNAME = process.env.ADMIN_USERNAME ?? '';\nconst PASSWORD = process.env.ADMIN_PASSWORD ?? '';\n\nasync function guardedLogin(page) {\n  await page.locator('input[type=\"email\"], input[name*=\"email\" i], input[name*=\"user\" i]').first().fill(USERNAME, { timeout: 4000 }).catch(() => {});\n  await page.locator('input[type=\"password\"], input[name*=\"password\" i]').first().fill(PASSWORD, { timeout: 4000 }).catch(() => {});\n  await page.locator('button[type=\"submit\"], input[type=\"submit\"]').first().click({ timeout: 4000 }).catch(() => {});\n  await page.waitForTimeout(2000);\n}\n\ntest.describe('Verify Keystone reflects Admin list-view changes with accessible list behavior', () => {\n  test('Verify Keystone reflects Admin list-view changes with accessible list behavior', async ({ page }, testInfo) => {\n    await page.goto('https://ops.acchindra.com/admin');\n    await page.waitForLoadState('domcontentloaded'); await page.waitForTimeout(1500);\n    await guardedLogin(page);\n    await expect.soft(page).toHaveURL(/\\/admin/);\n    // Inspection context was blocked and did not expose the admin list-view change; verify manually which Admin list-view configuration should propagate.\n    await testInfo.attach('step-1', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n\n    await page.goto('https://ops.acchindra.com/shockwave');\n    await page.waitForLoadState('domcontentloaded'); await page.waitForTimeout(1500);\n    await guardedLogin(page);\n    await expect.soft(page).toHaveURL(/\\/shockwave/);\n    await testInfo.attach('step-2', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n\n    await page.getByText('Email Logs').click({ timeout: 8000 }).catch(() => {});\n    await page.getByText('All Email Logs').click({ timeout: 8000 }).catch(() => {});\n    const reachableNavigation = await page.getByRole('navigation').count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await testInfo.attach('step-3', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n\n    const listContainer = page.getByRole('table').or(page.getByRole('grid')).or(page.getByRole('list')).first();\n    const listContainerCount = await listContainer.count().catch(() => 0);\n    const loadingCount = await page.locator('[aria-busy=\"true\"], [data-loading=\"true\"]').count().catch(() => 0);\n    const errorCount = await page.getByText(/Delivery Error|Failed/i).count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await testInfo.attach('step-4', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n    expect.soft(loadingCount, 'List view should not remain in an indefinite loading state.').toBe(0);\n    expect.soft(errorCount, 'List view should not show an error state.').toBe(0);\n\n    await page.reload();\n    await page.waitForLoadState('domcontentloaded'); await page.waitForTimeout(1500);\n    const reflectedListAfterReload = await page.getByRole('table').or(page.getByRole('grid')).or(page.getByRole('list')).first().count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await testInfo.attach('step-5', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n    expect.soft(reflectedListAfterReload, 'Blocked inspection did not identify a concrete Admin list-view change to compare in Keystone.').toBeGreaterThan(0);\n\n    await page.keyboard.press('Tab');\n    const activeElementHasName = await page.evaluate(() => {\n      const element = document.activeElement as HTMLElement | null;\n      if (!element || element === document.body) return false;\n      return Boolean(element.getAttribute('aria-label') || element.getAttribute('aria-labelledby') || element.textContent?.trim() || (element as HTMLInputElement).labels?.length);\n    });\n    const accessibleListFound = listContainerCount > 0 || reachableNavigation > 0;\n    await testInfo.attach('step-6', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n    expect.soft(activeElementHasName, 'Focused control should have an accessible name.').toBeTruthy();\n    expect(accessibleListFound, 'Keystone list context was not visible in the blocked inspection context; capture evidence and mark this case blocked until the target list-view is identified.').toBeTruthy();\n  });\n});\n"
              },
              {
                "test_case_title": "Verify Keystone reflects Admin list-view changes with accessible list behavior",
                "filename": "verify-keystone-reflects-admin-list-view-changes-with-accessible-list-behavior-tc-c51c-4.spec.ts",
                "code": "import { test, expect } from '@playwright/test';\n\nconst USERNAME = process.env.ADMIN_USERNAME ?? '';\nconst PASSWORD = process.env.ADMIN_PASSWORD ?? '';\n\nasync function guardedLogin(page) {\n  const usernameInput = page.locator('input[type=\"email\"], input[name=\"email\"], input[name=\"username\"], input[type=\"text\"]').first();\n  const passwordInput = page.locator('input[type=\"password\"]').first();\n  await usernameInput.fill(USERNAME, { timeout: 4000 }).catch(() => {});\n  await passwordInput.fill(PASSWORD, { timeout: 4000 }).catch(() => {});\n  await page.locator('button[type=\"submit\"]').first().click({ timeout: 4000 }).catch(() => {});\n  await page.waitForTimeout(2000);\n}\n\ntest.describe('Verify Keystone reflects Admin list-view changes with accessible list behavior', () => {\n  test('Verify Keystone reflects Admin list-view changes with accessible list behavior', async ({ page }, testInfo) => {\n    await page.goto('https://ops.acchindra.com/admin');\n    await page.waitForLoadState('domcontentloaded'); await page.waitForTimeout(1500);\n    await guardedLogin(page);\n    await expect.soft(page).toHaveURL(/\\/admin/);\n    // Inspection context was blocked and did not expose the admin list-view change; verify manually which Admin list-view configuration should propagate.\n    await testInfo.attach('step-1', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n\n    await page.goto('https://ops.acchindra.com/shockwave');\n    await page.waitForLoadState('domcontentloaded'); await page.waitForTimeout(1500);\n    await guardedLogin(page);\n    await expect.soft(page).toHaveURL(/\\/shockwave/);\n    await testInfo.attach('step-2', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n\n    await page.getByText('Email Logs').click({ timeout: 8000 }).catch(() => {});\n    await page.getByText('Deleted Records').click({ timeout: 8000 }).catch(() => {});\n    const reachableNavigation = await page.getByRole('navigation').count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await testInfo.attach('step-3', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n\n    const listContainer = page.getByRole('table').or(page.getByRole('grid')).or(page.getByRole('list')).first();\n    const listContainerCount = await listContainer.count().catch(() => 0);\n    const loadingCount = await page.getByText(/loading/i).count().catch(() => 0);\n    const errorCount = await page.getByText(/error|failed|something went wrong/i).count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await testInfo.attach('step-4', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n    expect.soft(loadingCount, 'List view should not remain in an indefinite loading state.').toBe(0);\n    expect.soft(errorCount, 'List view should not show an error state.').toBe(0);\n\n    await page.reload();\n    await page.waitForLoadState('domcontentloaded'); await page.waitForTimeout(1500);\n    const reflectedListAfterReload = await page.getByRole('table').or(page.getByRole('grid')).or(page.getByRole('list')).first().count().catch(() => 0);\n    await expect.soft(page.locator('body')).toBeVisible();\n    await testInfo.attach('step-5', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n    expect.soft(reflectedListAfterReload, 'Blocked inspection did not identify a concrete Admin list-view change to compare in Keystone.').toBeGreaterThan(0);\n\n    await page.keyboard.press('Tab');\n    const activeElementHasName = await page.evaluate(() => {\n      const element = document.activeElement as HTMLElement | null;\n      if (!element || element === document.body) return false;\n      return Boolean(element.getAttribute('aria-label') || element.getAttribute('aria-labelledby') || element.textContent?.trim() || (element as HTMLInputElement).labels?.length);\n    });\n    const accessibleListFound = listContainerCount > 0 || reachableNavigation > 0;\n    await testInfo.attach('step-6', { body: await page.screenshot({ fullPage: true }), contentType: 'image/png' });\n    expect.soft(activeElementHasName, 'Focused control should have an accessible name.').toBeTruthy();\n    expect(accessibleListFound, 'Keystone list context was not visible in the blocked inspection context; capture evidence and mark this case blocked until the target list-view is identified.').toBeTruthy();\n  });\n});\n"
