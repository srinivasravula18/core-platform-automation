            },
            {
              "action": "Navigate to /admin?nav=apps.",
              "expected": "The Admin single-page app switches to the Apps section."
            },
            {
              "action": "Verify a visible element labeled \"Apps\" is present in the current view.",
              "expected": "The Apps launcher or Apps section label is visible."
            },
            {
              "action": "Verify the current view is not one of the other documented Admin sections such as objects, tabs, roles, users, permissions, or audit_logs.",
              "expected": "The URL or active navigation state remains scoped to nav=apps."
            },
            {
              "action": "Confirm the view is ready for list verification.",
